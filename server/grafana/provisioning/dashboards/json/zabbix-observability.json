{
  "id": null,
  "uid": "zbx-observability",
  "title": "Zabbix Observability — Overview",
  "tags": ["zabbix", "opentelemetry", "zabbix-obs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    { "asDropdown": true, "type": "dashboards", "tags": ["zabbix-obs"], "title": "Dashboards", "icon": "external link", "includeVars": true, "keepTime": true, "keepFilters": true, "targetBlank": false }
  ],
  "templating": {
    "list": [
      {
        "name": "role", "type": "query", "label": "Papel",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(system_cpu_load_average_1m, zbx_role)", "refId": "role" },
        "includeAll": true, "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1, "sort": 1
      },
      {
        "name": "node", "type": "query", "label": "No",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(system_cpu_load_average_1m{zbx_role=~\"$role\"}, zbx_node)", "refId": "node" },
        "includeAll": true, "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1, "sort": 1
      }
    ]
  },
  "panels": [
    { "id": 1, "type": "row", "title": "Saude & visao geral", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false, "panels": [] },
    {
      "id": 2, "type": "stat", "title": "Nos saudaveis",
      "description": "Nos com o bridge lendo a stats interface (up == 1). Core standby fica 0 por design.",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(zabbix_stats_bridge_up{role=~\"$role\", node=~\"$node\"} == 1) or vector(0)", "refId": "A", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 3, "type": "stat", "title": "Cores ativos (HA)",
      "description": "Cores com trapper ativo. HA saudavel = 1. Se 0, nenhum core ativo = emergencia.",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(zabbix_stats_bridge_up{role=\"core\", node=~\"$node\"} == 1) or vector(0)", "refId": "A", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 4, "type": "stat", "title": "Hosts monitorados",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(zabbix_hosts_monitored{role=~\"$role\", node=~\"$node\"})", "refId": "A", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 5, "type": "stat", "title": "Items monitorados",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(zabbix_items_monitored{role=~\"$role\", node=~\"$node\"})", "refId": "A", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 6, "type": "stat", "title": "Items sem suporte",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(zabbix_items_unsupported{role=~\"$role\", node=~\"$node\"})", "refId": "A", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 100 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    {
      "id": 7, "type": "stat", "title": "Uptime (maior)",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(time() - zabbix_boottime_seconds{role=~\"$role\", node=~\"$node\"})", "refId": "A", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto", "justifyMode": "auto" }
    },
    { "id": 8, "type": "row", "title": "Status dos nos Zabbix", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false, "panels": [] },
    {
      "id": 9, "type": "table", "title": "Status por no (Zabbix)",
      "description": "Estado: core ativo=UP, core standby=STANDBY (azul), proxy down=DOWN (vermelho).",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(max by (node, role) (zabbix_stats_bridge_up{role=\"core\", role=~\"$role\", node=~\"$node\"}) + 1) or (max by (node, role) (zabbix_stats_bridge_up{role=\"proxy\", role=~\"$role\", node=~\"$node\"}) * 2)", "refId": "A", "instant": true, "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (node) (time() - zabbix_boottime_seconds{role=~\"$role\", node=~\"$node\"})", "refId": "B", "instant": true, "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (node) (zabbix_hosts_monitored{role=~\"$role\", node=~\"$node\"})", "refId": "C", "instant": true, "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (node) (zabbix_items_monitored{role=~\"$role\", node=~\"$node\"})", "refId": "D", "instant": true, "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (node) (zabbix_items_unsupported{role=~\"$role\", node=~\"$node\"})", "refId": "E", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "node", "mode": "outer" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true }, "renameByName": { "node": "No", "role": "Papel", "Value #A": "Estado", "Value #B": "Uptime", "Value #C": "Hosts", "Value #D": "Items", "Value #E": "Sem suporte" }, "indexByName": { "node": 0, "role": 1, "Value #A": 2, "Value #B": 3, "Value #C": 4, "Value #D": 5, "Value #E": 6 } } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Estado" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "STANDBY", "color": "blue", "index": 1 }, "2": { "text": "UP", "color": "green", "index": 2 } } } ] }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "blue", "value": 1 }, { "color": "green", "value": 2 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Uptime" }, "properties": [ { "id": "unit", "value": "s" } ] },
          { "matcher": { "id": "byName", "options": "Sem suporte" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 100 } ] } } ] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Papel", "desc": false } ] }
    },
    { "id": 10, "type": "row", "title": "Status do banco", "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }, "collapsed": false, "panels": [] },
    {
      "id": 11, "type": "table", "title": "PostgreSQL - status por no",
      "description": "pg_up, papel (primary/replica) e lag por no.",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (zbx_node) (pg_up{zbx_node=~\"$node\", zbx_node!=\"\"})", "refId": "A", "instant": true, "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (zbx_node) (pg_replication_is_replica{zbx_node=~\"$node\", zbx_node!=\"\"})", "refId": "B", "instant": true, "format": "table" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (zbx_node) (pg_replication_lag_seconds{zbx_node=~\"$node\", zbx_node!=\"\"})", "refId": "C", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "zbx_node", "mode": "outer" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true }, "renameByName": { "zbx_node": "No", "Value #A": "pg_up", "Value #B": "Papel", "Value #C": "Lag" }, "indexByName": { "zbx_node": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3 } } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "pg_up" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } } ] }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Papel" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "PRIMARY", "color": "green", "index": 0 }, "1": { "text": "REPLICA", "color": "blue", "index": 1 } } } ] }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "blue", "value": 1 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Lag" }, "properties": [ { "id": "unit", "value": "s" } ] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm" }
    },
    { "id": 12, "type": "row", "title": "Saude de servicos & nos", "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }, "collapsed": false, "panels": [] },
    {
      "id": 13, "type": "stat", "title": "php-fpm (up) por no",
      "description": "phpfpm_up por no web. Vermelho = php-fpm caido (mas no ainda reportando). Se o no inteiro cair, o tile some e vira heartbeat vermelho ao lado.",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (zbx_node) (phpfpm_up{zbx_node=~\"$node\", zbx_node!=\"\"})", "refId": "A", "instant": true, "legendFormat": "{{zbx_node}}" } ],
      "fieldConfig": { "defaults": { "unit": "none", "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "justifyMode": "auto" }
    },
    {
      "id": 14, "type": "table", "title": "Heartbeat - segundos desde a ultima coleta por no",
      "description": "time() - ultimo hostmetrics de cada no (janela 15m). Verde=fresco, vermelho=nao reporta ha >120s (no caido / rede / power). Cobre TODOS os papeis, inclusive web.",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "time() - max by (zbx_node) (max_over_time(timestamp(system_cpu_load_average_1m{zbx_node=~\"$node\", zbx_node!=\"\"})[15m:1m]))", "refId": "A", "instant": true, "format": "table" } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "zbx_node": "No", "Value": "Ultima coleta" }, "indexByName": { "zbx_node": 0, "Value": 1 } } } ],
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } }, "overrides": [ { "matcher": { "id": "byName", "options": "Ultima coleta" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 120 } ] } } ] } ] },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [ { "displayName": "Ultima coleta", "desc": true } ] }
    }
  ]
}
