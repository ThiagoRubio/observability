# Copie para .env e preencha. O .env fica FORA do git (.gitignore cobre *.env).
#   cp .env.example .env && nano .env
#
# Multiplos endpoints separados por virgula = failover (enquanto nao ha VIP/DNS).
ZABBIX_API_URL=http://10.55.0.132/api_jsonrpc.php,http://10.55.0.133/api_jsonrpc.php

# Token de LEITURA (Users -> API tokens). Regenere se ja vazou.
ZABBIX_API_TOKEN=coloque-o-token-aqui

# Opcionais:
# BRIDGE_PORT=9099
# ZABBIX_API_SEARCH=zabbix[
# API_TIMEOUT=10
